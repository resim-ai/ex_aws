{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 5am on monday"
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": [
      "at any time"
    ],
    "prCreation": "immediate",
    "labels": [
      "security"
    ],
    "major": {
      "enabled": true
    }
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 5am on monday"
    ]
  },
  "prConcurrentLimit": 6,
  "major": {
    "enabled": false
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Automerge GHA digest pins (low risk, paired with grouped GHA PR)",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "digest",
        "pinDigest"
      ],
      "automerge": true,
      "platformAutomerge": false
    },
    {
      "description": "Group all mix minor and patch updates into a single PR",
      "matchManagers": [
        "mix"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "mix minor and patch"
    },
    {
      "description": "Group Phoenix ecosystem updates",
      "matchManagers": [
        "mix"
      ],
      "matchPackageNames": [
        "phoenix",
        "phoenix_**"
      ],
      "groupName": "phoenix"
    },
    {
      "description": "Group Absinthe ecosystem updates",
      "matchManagers": [
        "mix"
      ],
      "matchPackageNames": [
        "absinthe",
        "absinthe_**"
      ],
      "groupName": "absinthe"
    }
  ]
}
